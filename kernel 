#!/sbin/sh
# MaheFooZ1710â„¢ â€” Mi A2 (jasmine_sprout) Boot Tuner

# â”€â”€ ZRAM (50% RAM, lz4, skip if already set) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
node=/sys/block/zram0
if [ -e "${node}/disksize" ]; then
  cur=$(cat "${node}/disksize" 2>/dev/null || echo 0)
  if [ "${cur}" = "0" ]; then
    ram_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    zram_size=$(( ram_kb * 1024 / 2 ))
    echo lz4 > "${node}/comp_algorithm" 2>/dev/null || true
    echo "${zram_size}" > "${node}/disksize"
    mkswap /dev/zram0   2>/dev/null || true
    swapon -p 100 /dev/zram0 2>/dev/null || true
  fi
fi

# â”€â”€ I/O Scheduler (eMMC = mmcblk0, UFS = sda/sdb) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
for dev in /sys/block/mmcblk0 /sys/block/sda /sys/block/sdb; do
  q="${dev}/queue"
  [ -d "${q}" ] || continue
  sched="${q}/scheduler"
  if ! grep -q '\[bfq\]' "${sched}" 2>/dev/null; then
    echo bfq        > "${sched}" 2>/dev/null || \
    echo mq-deadline > "${sched}" 2>/dev/null || true
  fi
  echo 0   > "${q}/iostats"       2>/dev/null || true
  echo 128 > "${q}/read_ahead_kb" 2>/dev/null || true
  echo 0   > "${q}/add_random"    2>/dev/null || true
done

# â”€â”€ VM / Memory â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
echo 100 > /proc/sys/vm/swappiness
echo 80  > /proc/sys/vm/vfs_cache_pressure
echo 10  > /proc/sys/vm/dirty_ratio
echo 5   > /proc/sys/vm/dirty_background_ratio
echo madvise > /sys/kernel/mm/transparent_hugepage/enabled 2>/dev/null || true

# â”€â”€ Network â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
echo 1 > /proc/sys/net/ipv4/tcp_fastopen   # client-side only (not 3 = server+client)

# â”€â”€ Sched features (requires CONFIG_SCHED_DEBUG, skip otherwise) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
[ -w /sys/kernel/debug/sched_features ] && \
  echo NO_GENTLE_FAIR_SLEEPERS > /sys/kernel/debug/sched_features

# â”€â”€ CPU Governor â€” schedutil first, interactive fallback â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
for pol in /sys/devices/system/cpu/cpufreq/policy*; do
  [ -d "${pol}" ] || continue
  avail="${pol}/scaling_available_governors"
  if grep -q schedutil "${avail}" 2>/dev/null; then
    echo schedutil > "${pol}/scaling_governor" 2>/dev/null || true
    echo 500 > "${pol}/schedutil/rate_limit_us" 2>/dev/null || true
  elif grep -q interactive "${avail}" 2>/dev/null; then
    echo interactive > "${pol}/scaling_governor" 2>/dev/null || true
    cpu=$(cat "${pol}/affected_cpus" 2>/dev/null | awk '{print $1}')
    idir="/sys/devices/system/cpu/cpu${cpu}/cpufreq/interactive"
    if [ -d "${idir}" ]; then
      if [ "${cpu:-0}" -ge 4 ] 2>/dev/null; then
        # Big cluster (cpu4-7) â€” SDM660
        echo 90     > "${idir}/go_hispeed_load" 2>/dev/null || true
        echo 800000 > "${idir}/hispeed_freq"    2>/dev/null || true
        echo 20000  > "${idir}/timer_rate"      2>/dev/null || true
      else
        # Little cluster (cpu0-3)
        echo 85     > "${idir}/go_hispeed_load" 2>/dev/null || true
        echo 600000 > "${idir}/hispeed_freq"    2>/dev/null || true
        echo 30000  > "${idir}/timer_rate"      2>/dev/null || true
      fi
      echo 0 > "${idir}/io_is_busy" 2>/dev/null || true
    fi
  fi
done

# â”€â”€ GPU â€” Adreno 512 (jasmine_sprout) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
GPU=/sys/class/kgsl/kgsl-3d0
if [ -d "${GPU}" ]; then
  echo simple_ondemand > "${GPU}/devfreq/governor" 2>/dev/null || true
  echo 4 > "${GPU}/min_pwrlevel" 2>/dev/null || true  # level 4 â‰ˆ 266 MHz on Adreno 512
fi

exit 0
