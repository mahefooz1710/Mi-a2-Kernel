on:
  workflow_dispatch:
    inputs:
      android_ver:
        description: "Android version (11=lineage-18.1 / 12=19.1 / 13=20 / 14=21)"
        required: true
        default: "11"
        type: choice
        options: ["11", "12", "13", "14"]
      localversion:
        description: "Kernel version suffix (CONFIG_LOCALVERSION)"
        required: false
        default: "-MaheFooZ1710"

env:
  # â”€â”€ User repos â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  PE_KERNEL_REPO:  "https://github.com/mahefooz1710/kernel_xiaomi_jasmine_sprout.git"
  LOS_KERNEL_REPO: "https://github.com/mahefooz1710/android_kernel_xiaomi_sdm660.git"
  CLANG_REPO:      "https://github.com/mahefooz1710/android_prebuilts_clang_host_linux-x86_clang-5220042.git"
  GCC64_REPO:      "https://github.com/mahefooz1710/android_prebuilts_gcc_linux-x86_aarch64_aarch64-linux-android-4.9.git"
  AK3_REPO:        "https://github.com/mahefooz1710/AnyKernel3.git"
  # â”€â”€ Official GCC32 (no arm32 repo in user's account) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  GCC32_REPO:      "https://github.com/LineageOS/android_prebuilts_gcc_linux-x86_arm_arm-linux-androideabi-4.9.git"
  # â”€â”€ Build constants â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  DEFCONFIG: "jasmine_sprout_defconfig"

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 120   # FIX A7: no timeout in original

    steps:
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 0 â€” Branch auto-select
      # FIX A4,A6,A8: all branches were hardcoded; added workflow_dispatch
      #               inputs + git ls-remote auto-detection with fallback
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      - name: ðŸ”¢ Auto-Select Branches
        id: br
        run: |
          set -euo pipefail
          AV="${{ inputs.android_ver }}"
          case "$AV" in
            11) LOS_BRANCH="lineage-18.1"; PE_BRANCH="twelve"   ;;
            12) LOS_BRANCH="lineage-19.1"; PE_BRANCH="thirteen" ;;
            13) LOS_BRANCH="lineage-20";   PE_BRANCH="thirteen" ;;
            14) LOS_BRANCH="lineage-21";   PE_BRANCH="fourteen" ;;
            *)  echo "âŒ Unknown android_ver: $AV"; exit 1 ;;
          esac

          # Returns: exact match â†’ latest lineage-* â†’ first available
          pick_branch() {
            local repo="$1" prefer="$2"
            local all result
            all=$(git ls-remote --heads "$repo" | sed 's|.*refs/heads/||')
            result=$(echo "$all" | grep -x "$prefer" | head -1 || true)
            [ -n "$result" ] && { echo "$result"; return; }
            result=$(echo "$all" | grep "^lineage-" | sort -V | tail -1 || true)
            [ -n "$result" ] && { echo "$result"; return; }
            echo "$all" | head -1
          }

          GCC64_BRANCH=$(pick_branch "$GCC64_REPO" "$LOS_BRANCH")
          GCC32_BRANCH=$(pick_branch "$GCC32_REPO" "$LOS_BRANCH")
          CLANG_BRANCH=$(git ls-remote --heads "$CLANG_REPO" \
            | sed 's|.*refs/heads/||' | head -1)
          CLANG_BRANCH="${CLANG_BRANCH:-9.0}"

          # AK3: prefer any jasmine branch, fall back to beryllium
          AK3_BRANCH=$(git ls-remote --heads "$AK3_REPO" \
            | sed 's|.*refs/heads/||' \
            | grep -iE "^jasmine" 2>/dev/null | head -1 || true)
          AK3_BRANCH="${AK3_BRANCH:-beryllium}"

          # Verify kernel branches actually exist
          for pair in "${LOS_KERNEL_REPO}:${LOS_BRANCH}" "${PE_KERNEL_REPO}:${PE_BRANCH}"; do
            repo="${pair%%:*}"; branch="${pair##*:}"
            git ls-remote --heads "$repo" \
              | grep -q "refs/heads/${branch}$" \
              || { echo "âŒ Branch '$branch' not found in $repo"; exit 1; }
          done

          BUILD_DATE=$(date +%Y%m%d-%H%M)

          {
            echo "LOS_BRANCH=${LOS_BRANCH}"
            echo "PE_BRANCH=${PE_BRANCH}"
            echo "GCC64_BRANCH=${GCC64_BRANCH}"
            echo "GCC32_BRANCH=${GCC32_BRANCH}"
            echo "CLANG_BRANCH=${CLANG_BRANCH}"
            echo "AK3_BRANCH=${AK3_BRANCH}"
            echo "BUILD_DATE=${BUILD_DATE}"
          } >> "$GITHUB_OUTPUT"

          printf '\nâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•\n'
          printf ' Android  : %s  â†’  %s\n' "$AV"         "$LOS_BRANCH"
          printf ' PE src   : %s\n'                        "$PE_BRANCH"
          printf ' GCC64    : %s\n'                        "$GCC64_BRANCH"
          printf ' GCC32    : %s\n'                        "$GCC32_BRANCH"
          printf ' Clang    : %s\n'                        "$CLANG_BRANCH"
          printf ' AK3      : %s\n'                        "$AK3_BRANCH"
          printf ' Date     : %s\n'                        "$BUILD_DATE"
          printf 'â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•\n\n'

      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 1 â€” Install dependencies
      # FIX A9,A10: added libelf-dev python3 cpio lz4 ccache pahole;
      #             added --no-install-recommends
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      - name: ðŸ“¦ Install Dependencies
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y --no-install-recommends \
            flex bison build-essential libssl-dev libelf-dev \
            bc wget git zip unzip python3 cpio lz4 ccache pahole

      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 2 â€” Clone toolchains
      # FIX A1: Clang was tar.gz from googlesource (unreliable) â†’ git clone
      # FIX A2: GCC64 was entirely missing â†’ git clone from user repo
      # FIX A3: GCC32 was tar.gz from googlesource â†’ git clone from LOS
      # FIX A5: AK3 was from osm0sis â†’ user repo 2
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      - name: ðŸ”§ Clone Clang
        run: |
          git clone --depth=1 \
            -b "${{ steps.br.outputs.CLANG_BRANCH }}" \
            "$CLANG_REPO" toolchain/clang
          echo "âœ… Clang: $(toolchain/clang/bin/clang --version | head -1)"

      - name: ðŸ”§ Clone GCC64
        run: |
          git clone --depth=1 \
            -b "${{ steps.br.outputs.GCC64_BRANCH }}" \
            "$GCC64_REPO" toolchain/gcc64

      - name: ðŸ”§ Clone GCC32
        run: |
          git clone --depth=1 \
            -b "${{ steps.br.outputs.GCC32_BRANCH }}" \
            "$GCC32_REPO" toolchain/gcc32

      # FIX C28,C2: original used step-level `env: PATH:` which does NOT expand
      # $PATH (it's a literal YAML string, not shell); moved to GITHUB_PATH.
      # FIX C27: added GCC64 bin/ (was completely missing from PATH)
      - name: ðŸ›¤ï¸ Export Toolchain PATH
        run: |
          echo "${{ github.workspace }}/toolchain/clang/bin" >> "$GITHUB_PATH"
          echo "${{ github.workspace }}/toolchain/gcc64/bin" >> "$GITHUB_PATH"
          echo "${{ github.workspace }}/toolchain/gcc32/bin" >> "$GITHUB_PATH"

      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 3 â€” Clone kernels
      # FIX F1,A8: PE kernel was full-history clone â†’ --filter=blob:none
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      - name: ðŸŒ¿ Clone PE Kernel (patch source)
        run: |
          git clone --filter=blob:none \
            -b "${{ steps.br.outputs.PE_BRANCH }}" \
            "$PE_KERNEL_REPO" pe_kernel

      - name: ðŸŒ¿ Clone LOS/SDM660 Kernel (compile target)
        run: |
          git clone --depth=1 \
            -b "${{ steps.br.outputs.LOS_BRANCH }}" \
            "$LOS_KERNEL_REPO" kernel

      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 4 â€” Extract patches from PE kernel
      # FIX F4: no git config before operations
      # FIX F5,F6: narrow grep patterns â†’ extended regex with alternates
      # FIX F3,F8: --zero-commit prevents filename collisions; extract helper
      # FIX F9: added success/fail counters
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      - name: ðŸ” Extract Patches (BFQ, BBR, simple_ondemand)
        working-directory: pe_kernel
        run: |
          git config user.email "ci@mahefooz1710.local"
          git config user.name "MaheFooZ1710 CI"
          mkdir -p ../patches

          extract() {
            local name="$1" pattern="$2"
            local commit
            commit=$(git log --oneline --all \
              --grep="$pattern" -i -E | head -1 | awk '{print $1}')
            if [ -n "$commit" ]; then
              echo "âœ… [$name] commit: $commit"
              git format-patch -1 "$commit" -o ../patches/ \
                --zero-commit --no-stat 2>/dev/null \
                && echo "   patch written" \
                || echo "âš ï¸  format-patch failed for $name"
            else
              echo "âš ï¸  [$name] no matching commit found"
            fi
          }

          extract "BFQ"             "bfq|block:.*bfq|iosched.*bfq"
          extract "BBR"             "bbr|tcp_bbr|add bbr|congestion.*bbr"
          extract "simple_ondemand" "simple_ondemand|adreno.*simple|msm.*simple"

          echo "â”€â”€ patches â”€â”€"
          ls -lh ../patches/ 2>/dev/null || echo "(none extracted)"

      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 5 â€” Apply patches
      # FIX F2: --check then apply is not atomic â†’ combined with --reject fallback
      # FIX F4: git config added
      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      - name: ðŸ©¹ Apply Patches to LOS Kernel
        working-directory: kernel
        run: |
          git config user.email "ci@mahefooz1710.local"
          git config user.name "MaheFooZ1710 CI"

          if ! ls ../patches/*.patch >/dev/null 2>&1; then
            echo "No patches to apply."; exit 0
          fi

          APPLIED=0; FAILED=0
          for patch in ../patches/*.patch; do
            name=$(basename "$patch")
            echo "â”€â”€ $name â”€â”€"
            if git apply --check "$patch" 2>/dev/null; then
              git apply "$patch" \
                && { echo "  âœ… applied"; APPLIED=$((APPLIED+1)); } \
                || { echo "  âŒ apply failed"; FAILED=$((FAILED+1)); }
            else
              echo "  âš ï¸  check failed â†’ trying --reject (partial apply)"
              git apply --reject "$patch" 2>/dev/null || true
              FAILED=$((FAILED+1))
            fi
          done
          echo "Result: âœ… Applied=${APPLIED}  âš ï¸ Failed=${FAILED}"

      # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
      # STEP 6 â€” Generate defconfig
      # FIX B1:  scripts/config was called as `cd out && scripts/config`
      #          â†’ scripts/config does not exist in out/; fixed with --file flag
      # FIX B2:  `cd out â€¦ cd ..` removed
      # FIX B3:  CONFIG_HZ is a Kconfig *choice*, not settable with --set-val
      #          â†’ must enable CONFIG_HZ_300 (and disable others)
      # FIX B4:  CONFIG_ZRAM_LZ4_COMPRESS doesn't exist â†’ CONFIG_CRYPTO_LZ4
      # FIX B5:  missing || true on non-optional configs
      # FIX B6-B9: removed aggressive disables (AUDIT/SYSRQ/DEBUG_KERNEL/SLUB_DEBUG)
      # FIX B10: WQ_POWER_EFFICIENT_DEFAULT missing || true
      # FIX B11: CONFIG_NET_SCH_FQ (BBR dependency) added
      # FIX B12: olddefconfig was missing ARCH=arm64 O=out
      # FIX B13: CONFIG_ZRAM_WRITEBACK added
      # FIX B14: CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL added
